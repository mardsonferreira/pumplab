# CORS: comma-separated origins (e.g. frontend URL)
ALLOWED_ORIGINS=http://localhost:3000

# Redirect after auth callback
FRONTEND_URL=http://localhost:3000

# Cookie "secure" flag: false for localhost (HTTP), true in production (HTTPS)
# SECURE_COOKIES=false

# Supabase (service role for admin; anon for validating user JWT)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
# Set to true to skip real OpenAI calls during local development
USE_MOCK_LLM=false
